# Twilio credentials (get from https://console.twilio.com/)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Optional: Groq API key for smarter AI replies (free tier at console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxx

# Recommended for AI voice: free ngrok token from https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=your_ngrok_token

# Optional: public URL if auto-tunnel fails
# PUBLIC_WEBHOOK_URL=https://xxxx.ngrok-free.app

# API server port (default 3001)
PORT=3001

# Prospect Finder — free registry keys (optional; demo works without them)
# UK: https://developer.company-information.service.gov.uk/
# COMPANIES_HOUSE_API_KEY=your_free_api_key_here
# Australia: https://abr.business.gov.au/Tools/WebServices
# ABR_GUID=your_free_abr_guid_here

# Maps Lead Finder — optional Google Places API for full Maps-style search
# GOOGLE_PLACES_API_KEY=your_google_places_api_key

# --- Cloud server (Render / production) ---
# NODE_ENV=production
# ENABLE_TUNNEL=false
# On Render, PUBLIC_WEBHOOK_URL is auto-set via RENDER_EXTERNAL_URL.
# Custom domain only:
# PUBLIC_WEBHOOK_URL=https://lagnaa.yourdomain.com