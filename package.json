{
  "name": "ai-call-crm",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/index.ts",
    "dev:all": "npm run dev",
    "build": "tsc -b && vite build",
    "start": "NODE_ENV=production node --import tsx server/index.ts",
    "start:win": "set NODE_ENV=production&& tsx server/index.ts",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ngrok/ngrok": "^1.7.0",
    "@types/ws": "^8.18.1",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "framer-motion": "^12.42.0",
    "localtunnel": "^2.0.2",
    "lucide-react": "^1.21.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "puppeteer": "^25.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "twilio": "^5.4.5",
    "tsx": "^4.19.2",
    "ws": "^8.21.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.13.2",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.2",
    "concurrently": "^9.1.2",
    "oxlint": "^1.69.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  }
}
